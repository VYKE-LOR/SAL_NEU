NODE_ENV=development
PORT=4000

# Option A: Einzelwerte (empfohlen für lokale phpMyAdmin/MySQL-Setups)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sal_bot
DB_USER=root
DB_PASSWORD=

# Option B: Vollständige URL (überschreibt Einzelwerte)
# DATABASE_URL=mysql://root:password@127.0.0.1:3306/sal_bot

SESSION_SECRET=change-me-to-a-long-random-secret-32-char-min
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:4000/auth/discord/callback
DISCORD_BOT_TOKEN=
